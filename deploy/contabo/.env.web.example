NODE_ENV=production
PORT=3000

NEXT_PUBLIC_SITE_URL=https://blog.jackihyun.com
NEXT_PUBLIC_SITE_NAME=Jackihyun 개발 블로그
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=replace-with-google-site-verification-token
NEXT_PUBLIC_API_URL=http://127.0.0.1:8081/api
NEXT_PUBLIC_API_PROXY_PATH=/api

NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_REACTIONS=true
NEXT_PUBLIC_ENABLE_LEGACY_FILE_POSTS=false

AUTH_SECRET=replace-with-nextauth-secret
AUTH_TRUST_HOST=true

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
